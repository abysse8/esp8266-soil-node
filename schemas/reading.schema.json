{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SensorReading",
  "type": "object",
  "required": ["device_id", "type", "uptime_ms", "capabilities", "sensors"],
  "properties": {
    "device_id":    { "type": "string" },
    "type":         { "type": "string" },
    "broker":       { "type": "string" },
    "uptime_ms":    { "type": "integer" },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "sensors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["channel", "raw", "moisture_pct"],
        "properties": {
          "channel":      { "type": "integer", "minimum": 0, "maximum": 7 },
          "raw":          { "type": "integer", "minimum": 0, "maximum": 1023 },
          "moisture_pct": { "type": "integer", "minimum": 0, "maximum": 100 }
        }
      }
    }
  }
}
