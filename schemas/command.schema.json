{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeviceCommand",
  "type": "object",
  "required": ["command"],
  "properties": {
    "command": {
      "type": "string",
      "enum": ["start_livemonitor", "stop_livemonitor"]
    },
    "interval_ms":   { "type": "integer", "minimum": 100, "maximum": 60000 },
    "duration_sec":  { "type": "integer", "minimum": 1, "maximum": 3600 }
  }
}
